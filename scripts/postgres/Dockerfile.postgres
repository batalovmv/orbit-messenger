FROM postgres:16-alpine
RUN apk add --no-cache curl bash
RUN curl -L https://github.com/wal-g/wal-g/releases/download/v3.0.3/wal-g-pg-ubuntu-amd64.tar.gz | tar xz -C /usr/local/bin/ || echo "WAL-G binary may need different arch, check release page"
COPY wal-g.env.sh /etc/wal-g.env.sh
COPY setup-archiving.sh /docker-entrypoint-initdb.d/99-setup-archiving.sh
