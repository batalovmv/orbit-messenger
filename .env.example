# ============================================================
# Orbit Messenger — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit real secrets to git — use Saturn panel for production.

# === Database ===
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=changeme_postgres_password

# === Redis ===
REDIS_PASSWORD=changeme_redis_password

# === JWT ===
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# === Internal Service Auth (must be identical on gateway, auth, messaging, media) ===
INTERNAL_SECRET=changeme_internal_secret_at_least_32_chars

# === Backups (scripts/backup-postgres.sh) ===
# Symmetric GPG passphrase for nightly pg_dump uploads to R2. Keep it
# separate from R2 credentials — anyone holding both can restore the DB.
# MUST be at least 32 characters; the script enforces that.
BACKUP_ENCRYPTION_PASSPHRASE=changeme_backup_passphrase_at_least_32_chars
# Name of the R2 bucket reserved for backups (separate from media bucket).
R2_BACKUP_BUCKET=orbit-backups

# === At-rest Message Encryption ===
# 32+ char secret used by the messaging service to AES-256-GCM encrypt every
# `messages.content` row before it hits Postgres. A stolen DB dump without
# this key reveals only ciphertext. MUST be backed up alongside the DB —
# losing it means losing the ability to read historical messages.
# Rotate only by dumping + re-encrypting the messages table (no automatic
# rotation yet — planned for Phase 8D).
ORBIT_MESSAGE_ENCRYPTION_KEY=changeme_at_rest_key_at_least_32_chars

# === TOTP (2FA) ===
TOTP_ISSUER=Orbit

# === Admin ===
# Key for admin password reset endpoint (leave empty to disable)
ORBIT_ADMIN_RESET_KEY=
# Bootstrap secret gates /auth/bootstrap. Set to a strong value ONLY during
# initial provisioning, then clear and restart the auth service. When empty,
# the endpoint is hard-disabled.
BOOTSTRAP_SECRET=

# === Frontend ===
FRONTEND_URL=http://localhost:3000

# === NATS (must be identical on gateway, messaging, media, and nats --auth flag) ===
NATS_TOKEN=changeme_nats_auth_token

# Bots service
BOT_TOKEN_SECRET=change-me-to-a-random-64-char-string

# Service URLs (used by gateway for proxying)
BOTS_SERVICE_URL=http://localhost:8086
INTEGRATIONS_SERVICE_URL=http://localhost:8087
AI_SERVICE_URL=http://localhost:8085

# === AI service (Phase 8A) ===
# Leave as "placeholder" to run the service in degraded mode where every
# /ai/* endpoint returns 503 service_unavailable. Swap real keys on Saturn.ac
# dashboard without rebuilding the image.
ANTHROPIC_API_KEY=placeholder
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=placeholder
WHISPER_MODEL=whisper-1

# === Meilisearch (MEILI_MASTER_KEY = MEILISEARCH_KEY, must match) ===
MEILI_MASTER_KEY=changeme_meilisearch_key
MEILISEARCH_KEY=changeme_meilisearch_key

# === Tenor GIF API ===
TENOR_API_KEY=

# === VAPID (Web Push — generate with: go run ./services/gateway/cmd/generate-vapid) ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBSCRIBER_EMAIL=mailto:push@orbit.local

# === Media / R2 Storage ===
# For local dev (MinIO): defaults work out of the box
# For production: set to Cloudflare R2 credentials
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=orbit-media
# Separate bucket for WAL-G PostgreSQL backups (used by scripts/postgres/)
R2_BACKUP_WAL_BUCKET=orbit-backups
R2_PUBLIC_ENDPOINT=http://localhost:9000
# Apply a public-read bucket policy on startup. ONLY honored on local
# endpoints (localhost / 127.0.0.1 / minio / host.docker.internal); on any
# other endpoint (Cloudflare R2, AWS S3, prod cluster) the media service
# refuses to start if this is true. In production, configure CDN / public
# asset access at the provider level instead — never bucket-wide.
R2_APPLY_PUBLIC_POLICY=false
# Leave empty or 0 to disable (recommended for corporate deployments).
MAX_USER_STORAGE_BYTES=0

# === Inter-service URLs (override when running outside Docker) ===
INTEGRATIONS_URL=http://localhost:8087

# === Sticker seed CLI ===
MEDIA_SERVICE_URL=http://localhost:8083
STICKER_SEED_UPLOADER_ID=
TELEGRAM_BOT_TOKEN=

# === Calls / WebRTC ===
# REQUIRED: compose will fail without these values. Never use 'orbit:orbit'.
# coturn credentials (shared with coturn container --user flag)
TURN_REALM=orbit.local
TURN_USER=orbit
TURN_PASSWORD=changeme_turn_password
# Recommended: enables short-lived REST auth credentials (RFC 7635).
# coturn must be configured with: use-auth-secret + static-auth-secret=<same value>
# When set, calls service mints per-user TURN credentials (username=timestamp:userID, password=HMAC-SHA1).
# Leave empty to fall back to static TURN_USER/TURN_PASSWORD (less secure).
# Generate with: openssl rand -hex 32
TURN_SHARED_SECRET=
# Internal URL — used by calls service for logging only (not sent to clients).
TURN_URL=turn:coturn:3478
# Public URL — returned to browser clients. MUST be reachable from user browsers.
# Dev (browser on same host as Docker): turn:host.docker.internal:3478
# Prod: set to your server's public IP or domain, e.g. turn:1.2.3.4:3478
# Saturn: set TURN_PUBLIC_URL=turn:<saturn-vm-ip>:3478 in the Saturn env panel.
TURN_PUBLIC_URL=turn:host.docker.internal:3478

# ClamAV antivirus scanning (media uploads)
CLAMAV_ADDR=clamav:3310
CLAMAV_TIMEOUT=10s

# === Monitoring / Alertmanager ===
# Full webhook URL for Alertmanager → Orbit integration.
# Format: https://orbit.yourdomain.com/webhooks/in/<connector-id>
# Create a connector with preset=alertmanager in Orbit Settings → Integrations,
# then paste the generated URL here.
ALERTMANAGER_WEBHOOK_URL=
# Bearer token secret — copy from the connector's "Secret" field after creation.
ALERTMANAGER_WEBHOOK_SECRET=

# === External Healthcheck (scripts/healthcheck.sh) ===
# Base URL of the Orbit gateway (same as FRONTEND_URL without trailing slash).
ORBIT_BASE_URL=http://localhost:8080
# Webhook URL for healthcheck failure alerts (can reuse the same connector as
# Alertmanager or create a separate one with preset=generic).
HEALTHCHECK_WEBHOOK_URL=
# Bearer token secret for the healthcheck webhook connector.
HEALTHCHECK_SECRET=
# Timeout in seconds for each health probe (default: 5).
HEALTHCHECK_TIMEOUT=5
