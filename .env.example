# =============================================================================
# Orbit Messenger — Environment Variables
# =============================================================================
# Copy to .env and fill in real values before running docker-compose
# =============================================================================

# --- Database (PostgreSQL 16) ---
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=          # REQUIRED: generate a strong password
DATABASE_URL=postgresql://orbit:YOUR_PASSWORD@localhost:5432/orbit?sslmode=disable

# --- Cache (Redis 7) ---
REDIS_PASSWORD=             # REQUIRED: generate a strong password
REDIS_URL=redis://:YOUR_PASSWORD@localhost:6379/0

# --- Message Queue (NATS JetStream) ---
NATS_URL=nats://localhost:4222

# --- Search (Meilisearch 1.7) ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=            # REQUIRED: generate a master key

# --- JWT ---
JWT_SECRET=                 # REQUIRED: min 32 random chars. NEVER use default values
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h        # 30 days

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Service Ports ---
GATEWAY_PORT=8080
AUTH_PORT=8081
MESSAGING_PORT=8082
MEDIA_PORT=8083
CALLS_PORT=8084
AI_PORT=8085
BOTS_PORT=8086
INTEGRATIONS_PORT=8087

# --- Inter-service URLs (docker-compose uses service names) ---
AUTH_SERVICE_URL=http://localhost:8081
MESSAGING_SERVICE_URL=http://localhost:8082
MEDIA_SERVICE_URL=http://localhost:8083

# --- Cloudflare R2 (Phase 3: Media) ---
R2_ENDPOINT=                # https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=orbit-media

# --- AI (Phase 8) ---
ANTHROPIC_API_KEY=

# --- Push Notifications (Phase 4) ---
VAPID_PUBLIC_KEY=           # generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=

# --- TURN Server (Phase 6: Calls) ---
TURN_URL=turn:localhost:3478
TURN_REALM=orbit.local
TURN_USER=orbit
TURN_PASSWORD=

# --- 2FA ---
TOTP_ISSUER=Orbit

# --- Admin Reset ---
ORBIT_ADMIN_RESET_KEY=      # REQUIRED for admin password reset via POST /auth/reset-admin

# --- App ---
APP_NAME=Orbit
APP_VERSION=0.1.0
APP_ENV=development         # development | staging | production
