# ============================================================
# Orbit Messenger — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to git — it contains secrets.

# === Database ===
POSTGRES_DB=orbit
POSTGRES_USER=orbit
POSTGRES_PASSWORD=changeme_postgres_password

# === Redis ===
REDIS_PASSWORD=changeme_redis_password

# === JWT ===
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# === TOTP (2FA) ===
TOTP_ISSUER=Orbit

# === Admin ===
# Key for admin password reset endpoint (leave empty to disable)
ORBIT_ADMIN_RESET_KEY=

# === Frontend ===
FRONTEND_URL=http://localhost:3000

# === Meilisearch ===
MEILISEARCH_KEY=changeme_meilisearch_key

# === Media / R2 Storage ===
# For local dev (MinIO): defaults work out of the box
# For production: set to Cloudflare R2 credentials
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=orbit-media
R2_PUBLIC_ENDPOINT=http://localhost:9000
